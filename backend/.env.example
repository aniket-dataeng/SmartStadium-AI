# SmartStadium-AI Backend — Environment Variables
# Copy this file to .env and fill in the values

# Allowed CORS origins (comma-separated for multiple)
CORS_ORIGINS=http://localhost:5173

# How often (in seconds) the simulation broadcasts IoT data to clients
BROADCAST_INTERVAL_SECS=6

# Optional: set to "production" to enable stricter settings
APP_ENV=development
